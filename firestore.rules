rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their own data
    match /businessMapNodes/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /businessMapEdges/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /businessMapLayouts/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    // Allow test collection for debugging
    match /test/{document} {
      allow read, write: if request.auth != null;
    }
    // Allow any authenticated user to read/write their own workspace data
    match /workspaceNotes/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /workspaceTasks/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /chatMessages/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /mentions/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /timeEntries/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /workspaceLayouts/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /activityFeed/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /calendarEvents/{document} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
