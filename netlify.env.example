# Netlify Environment Variables Template
# Add these variables to Netlify dashboard under Site settings > Environment variables

# Build settings
NODE_VERSION=18
NPM_VERSION=9

# App settings (add your own as needed)
# VITE_API_URL=https://your-api-url.com
# VITE_APP_NAME=Nexus AI
# VITE_ENVIRONMENT=production

# Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=your-ga-id
# VITE_GOOGLE_TAG_MANAGER_ID=your-gtm-id

# Feature flags (optional)
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_DEBUG=false
